VITE_API_BASE=http://localhost:4000

# --- Code execution backend --------------------------------------------------
# Choose where /Run/ executes user code.
#   codex  = Auto-fallback chain: Wandbox -> CodeX -> Agent Code Runner.
#            All free, no signup, no card. **Recommended default.**
#   wandbox= Wandbox only (free, no key, ~20 langs)
#   agent  = Agent Code Runner only (free, no key, py/js/ts/bash only)
#   judge0 = RapidAPI-hosted Judge0 (paid since 2026 - $0.0017/run, requires key)
#   piston = Piston (self-host via Docker; public emkc whitelist-only)
VITE_EXEC_BACKEND=codex

# --- Wandbox (primary in auto chain) -----------------------------------------
# No key needed. https://wandbox.org/api/
VITE_WANDBOX_URL=https://wandbox.org/api/compile.json

# --- CodeX (auto-chain fallback) ---------------------------------------------
# No key needed. Override only if you self-host: https://github.com/Jaagrav/CodeX-API
VITE_CODEX_URL=https://api.codex.jaagrav.in

# --- Agent Code Runner (auto-chain fallback / standalone) --------------------
# No key needed. 30 req/min free tier. Python/JS/TS/Bash only.
VITE_AGENT_URL=https://agent-gateway-kappa.vercel.app/v1/agent-coderunner/api/execute

# --- Judge0 (when VITE_EXEC_BACKEND=judge0) ----------------------------------
# Sign up: https://rapidapi.com/judge0-official/api/judge0-ce
VITE_JUDGE0_HOST=judge0-ce.p.rapidapi.com
VITE_JUDGE0_KEY=

# --- Piston (when VITE_EXEC_BACKEND=piston) ----------------------------------
# Public emkc (whitelist-only as of Feb 2026):
#   VITE_PISTON_URL=https://emkc.org/api/v2/piston
# Self-hosted Docker instance:
#   VITE_PISTON_URL=http://localhost:2000/api/v2
VITE_PISTON_URL=https://emkc.org/api/v2/piston
