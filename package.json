{
  "name": "vaartalaap",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0 <21"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm --workspace @vaartalaap/server run dev",
    "dev:client": "npm --workspace @vaartalaap/client run dev",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "typecheck": "npm run typecheck --workspaces"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5"
  }
}
